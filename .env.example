# Application
APP_NAME="Plateforme Livraison"
APP_VERSION="1.0.0"
DEBUG=True
API_PREFIX="/api/v1"

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/livraison_db
DATABASE_TEST_URL=postgresql+asyncpg://user:password@localhost:5432/livraison_test_db

# Security
SECRET_KEY=your-secret-key-here-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# SMS / OTP (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Firebase (for notifications)
FIREBASE_CREDENTIALS_PATH=path/to/firebase-credentials.json

# Cloudflare R2 (stockage documents)
# Créer un bucket "sonaiyaa-documents" dans Cloudflare R2, puis générer une clé API R2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=sonaiyaa-documents
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev

# Redis
REDIS_URL=redis://localhost:6379/0

# Geolocation
DEFAULT_SEARCH_RADIUS_KM=5.0
MAX_SEARCH_RADIUS_KM=10.0
MIN_SEARCH_RADIUS_KM=1.0

# Commission
PLATFORM_COMMISSION_PERCENTAGE=15.0

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]
